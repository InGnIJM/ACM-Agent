{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/main.ts"
  ],
  "coverageDirectory": "./coverage-e2e",
  "coverageThreshold": {
    "global": {
      "statements": 70,
      "branches": 60,
      "functions": 70,
      "lines": 70
    }
  },
  "testTimeout": 30000,
  "maxWorkers": 1,
  "verbose": true
}
